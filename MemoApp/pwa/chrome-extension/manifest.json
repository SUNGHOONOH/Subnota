{
  "manifest_version": 3,
  "name": "Subnota Capture",
  "description": "Save the current Chrome tab to Subnota Inbox.",
  "version": "0.1.0",
  "action": {
    "default_title": "Save to Subnota"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "commands": {
    "save-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current page to Subnota"
    }
  },
  "host_permissions": [
    "https://subnota.com/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*"
  ],
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ]
}
