{
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@tiptap/react/menus": ["./node_modules/@tiptap/react/dist/menus/index.d.ts"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    ".vite",
    "forge.config.ts",
    "src/__tests__"
  ]
}
